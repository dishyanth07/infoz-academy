rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      // For demo purposes, we're allowing access. 
      // In production, you should use Firebase Auth.
      return true; 
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "dishyanths@gmail.com");
    }

    // User rules
    match /users/{userId} {
      allow read, write: if true;
    }

    // Notes rules
    match /notes/{noteId} {
      allow read, write: if true;
    }

    // Question Papers rules
    match /questionPapers/{paperId} {
      allow read, write: if true;
    }

    // Test Schedules rules
    match /testSchedules/{scheduleId} {
      allow read, write: if true;
    }

    // Students rules
    match /students/{studentId} {
      allow read, write: if true;
    }

    // Attendance rules
    match /attendance/{date} {
      allow read, write: if true;
    }

    // Fees rules
    match /fees/{feeId} {
      allow read, write: if true;
    }

    // Marks rules
    match /marks/{markId} {
      allow read, write: if true;
    }

    // Students rules
    match /students/{studentId} {
      allow read, write: if true;
    }
  }
}
